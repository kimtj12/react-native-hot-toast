{
  "name": "@kimtj12/react-native-hot-toast",
  "version": "0.1.0",
  "description": "Smoking hot React Native notifications. Faithful port of react-hot-toast with polished animations powered by Reanimated v4.",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/commonjs/src/index.d.ts",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "react-native": "./src/index.ts",
      "types": "./lib/typescript/commonjs/src/index.d.ts",
      "import": "./lib/module/index.js",
      "require": "./lib/commonjs/index.js"
    },
    "./headless": {
      "source": "./src/headless/index.ts",
      "react-native": "./src/headless/index.ts",
      "types": "./lib/typescript/commonjs/src/headless/index.d.ts",
      "import": "./lib/module/headless/index.js",
      "require": "./lib/commonjs/headless/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "!**/*.test.ts",
    "!**/*.test.tsx",
    "!**/__tests__"
  ],
  "scripts": {
    "build": "bob build",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf lib"
  },
  "keywords": [
    "react-native",
    "expo",
    "toast",
    "notifications",
    "snackbar",
    "react-hot-toast"
  ],
  "author": "kimskulltj",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kimtj12/react-native-hot-toast.git",
    "directory": "packages/react-native-hot-toast"
  },
  "homepage": "https://github.com/kimtj12/react-native-hot-toast#readme",
  "bugs": {
    "url": "https://github.com/kimtj12/react-native-hot-toast/issues"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.76.0",
    "react-native-gesture-handler": ">=2.20.0",
    "react-native-reanimated": ">=3.16.0",
    "react-native-safe-area-context": ">=4.10.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.17",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-builder-bob": "^0.32.0",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.7",
    "react-native-safe-area-context": "5.6.2",
    "react-native-worklets": "0.5.1",
    "typescript": "~5.9.3"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      ["commonjs", { "esm": true }],
      ["module", { "esm": true }],
      ["typescript", { "project": "tsconfig.build.json", "esm": true }]
    ]
  }
}
